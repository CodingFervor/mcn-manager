{
  "appId": "com.mcnmanager.app",
  "appName": "MCN管家",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "androidSplashResourceName": "splash",
      "backgroundColor": "#0a0e27",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0a0e27"
    }
  }
}